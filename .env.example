# =============================================================================
# remis_app — Variables de entorno (raíz del monorepo)
# =============================================================================
#
# Copiar este archivo a `.env` y completar con valores reales.
# El `.env` real NUNCA debe commitearse (está en .gitignore).
#
# Para regenerar los archivos derivados (Flutter dev.json, web .env.local, etc.)
# ejecutar:
#     pnpm env:sync
#
# Esto se corre automáticamente desde el Play button de Cursor/VSCode.
# =============================================================================

# -----------------------------------------------------------------------------
# Entorno activo: dev | stg | prd
# Determina contra qué Supabase apunta `pnpm env:sync` por default.
# -----------------------------------------------------------------------------
ENVIRONMENT=dev

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Para desarrollo local con `supabase start`:
#   SUPABASE_URL=http://127.0.0.1:54321
#   SUPABASE_ANON_KEY=<copiar de `supabase status`>
#
# Para staging/prod: copiar de https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# Service-role key (SOLO para edge functions / scripts admin — NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Google Maps (driver, passenger, dispatcher)
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Mercado Pago (passenger)
# -----------------------------------------------------------------------------
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# PostHog (analytics dispatcher — opcional en dev)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Sentry (observabilidad — opcional en dev)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Overrides por entorno (opcional)
# -----------------------------------------------------------------------------
# Si querés mantener distintos valores para staging/prod sin tocar el .env:
#   - Crear `.env.staging` con las mismas keys → genera `stg.json`
#   - Crear `.env.production` con las mismas keys → genera `prd.json`
# Estos archivos también están gitignored.
