# Copy this file to apps/dispatcher/.env.local and fill in real values.
# Never commit real keys or passwords.

# Base URL where the dispatcher Next.js app is served during E2E runs.
E2E_BASE_URL=http://localhost:3001

# Local Supabase (supabase start) or remote project URL.
SUPABASE_URL=http://localhost:54321

# Service-role key — allows writing test data directly bypassing RLS.
# Find it with: supabase status  (look for "service_role key")
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dispatcher-role user credentials (must exist in auth.users + profiles with role=dispatcher).
TEST_DISPATCHER_EMAIL=dispatcher@test.com
TEST_DISPATCHER_PASSWORD=test123456

# Passenger-role user credentials (must exist in auth.users + profiles with role=passenger).
# Used to verify that passenger accounts are blocked from the dispatcher panel.
TEST_PASSENGER_EMAIL=passenger@test.com
TEST_PASSENGER_PASSWORD=test123456

# UUID of the passenger used as passenger_id when inserting test rides.
TEST_PASSENGER_ID=00000000-0000-0000-0000-000000000001
