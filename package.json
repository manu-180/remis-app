{
  "name": "remis-app",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo para app de remisería single-tenant (driver, passenger, dispatcher, web).",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "env:sync": "node scripts/sync-env.mjs",
    "env:check": "node scripts/sync-env.mjs --check",
    "predev": "node scripts/sync-env.mjs --env dev",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
